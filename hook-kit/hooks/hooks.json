            "command": "uvx --from \"${CLAUDE_PLUGIN_ROOT}\" claude-hooks dispatch SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from \"${CLAUDE_PLUGIN_ROOT}\" claude-hooks dispatch UserPromptSubmit"
