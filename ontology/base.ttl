@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix mem:  <https://memory.claude.local/ontology#> .

# --- Ontology metadata ---
mem: a owl:Ontology ;
    rdfs:label "Claude Memory Graph Ontology" ;
    rdfs:comment "Arches-inspired hybrid knowledge graph for Claude Code long-term memory. Each resource instance gets its own named graph. Scalar attributes are flat properties; shared concepts are traversable nodes enabling multi-hop recall." ;
    owl:versionInfo "0.2.0" .

# ============================================================
# RESOURCE MODELS (graph types — each instance is a named graph)
# ============================================================

mem:ResourceModel a rdfs:Class ;
    rdfs:label "Resource Model" ;
    rdfs:comment "A schema definition for a type of resource graph." .

mem:Person a rdfs:Class ;
    rdfs:subClassOf mem:ResourceModel ;
    rdfs:label "Person" ;
    rdfs:comment "A person: user, teammate, stakeholder." .

mem:Project a rdfs:Class ;
    rdfs:subClassOf mem:ResourceModel ;
    rdfs:label "Project" ;
    rdfs:comment "A codebase, repository, or initiative." .

mem:Company a rdfs:Class ;
    rdfs:subClassOf mem:ResourceModel ;
    rdfs:label "Company" ;
    rdfs:comment "An organisation or business." .

mem:Task a rdfs:Class ;
    rdfs:subClassOf mem:ResourceModel ;
    rdfs:label "Task" ;
    rdfs:comment "A work item, ticket, or objective." .

mem:Technology a rdfs:Class ;
    rdfs:subClassOf mem:ResourceModel ;
    rdfs:label "Technology" ;
    rdfs:comment "A language, framework, tool, or platform." .

mem:Decision a rdfs:Class ;
    rdfs:subClassOf mem:ResourceModel ;
    rdfs:label "Decision" ;
    rdfs:comment "A choice that was made, with rationale." .

mem:Pattern a rdfs:Class ;
    rdfs:subClassOf mem:ResourceModel ;
    rdfs:label "Pattern" ;
    rdfs:comment "A recurring approach, anti-pattern, or best practice." .

# ============================================================
# CONCEPT TYPES (shared nodes — lightweight, traversable)
# ============================================================

mem:ConceptType a rdfs:Class ;
    rdfs:label "Concept Type" ;
    rdfs:comment "Base class for shared concept nodes." .

mem:Skill a rdfs:Class ;
    rdfs:subClassOf mem:ConceptType ;
    rdfs:label "Skill" ;
    rdfs:comment "Links a Person to a Technology or domain with proficiency." .

mem:Concept a rdfs:Class ;
    rdfs:subClassOf mem:ConceptType ;
    rdfs:label "Concept" ;
    rdfs:comment "An abstract topic, domain term, or architectural idea." .

mem:Constraint a rdfs:Class ;
    rdfs:subClassOf mem:ConceptType ;
    rdfs:label "Constraint" ;
    rdfs:comment "A limitation, requirement, or compliance rule." .

mem:Preference a rdfs:Class ;
    rdfs:subClassOf mem:ConceptType ;
    rdfs:label "Preference" ;
    rdfs:comment "How someone likes to work or a favoured approach." .

# ============================================================
# SCALAR PROPERTIES (flat on resource instances — fast, one hop)
# ============================================================

# Common to all resources
mem:name a rdf:Property ; rdfs:label "name" ;
    rdfs:comment "Primary name identifier for any resource." .
mem:description a rdf:Property ; rdfs:label "description" .
mem:createdAt a rdf:Property ; rdfs:range xsd:dateTime .
mem:updatedAt a rdf:Property ; rdfs:range xsd:dateTime .

# Person scalars
mem:email a rdf:Property ; rdfs:domain mem:Person .
mem:role a rdf:Property ; rdfs:domain mem:Person .
mem:address a rdf:Property ; rdfs:domain mem:Person .

# Project scalars
mem:projectType a rdf:Property ; rdfs:domain mem:Project ;
    rdfs:comment "e.g. code, design, research" .
mem:startDate a rdf:Property ; rdfs:domain mem:Project ; rdfs:range xsd:date .
mem:status a rdf:Property .
mem:progress a rdf:Property ; rdfs:domain mem:Project .
mem:path a rdf:Property ; rdfs:comment "File system path." .
mem:url a rdf:Property .

# Company scalars
mem:industry a rdf:Property ; rdfs:domain mem:Company .
mem:website a rdf:Property ; rdfs:domain mem:Company .

# Task scalars
mem:deadline a rdf:Property ; rdfs:domain mem:Task ; rdfs:range xsd:date .
mem:priority a rdf:Property ; rdfs:domain mem:Task .

# Technology scalars
mem:version a rdf:Property ; rdfs:domain mem:Technology .
mem:category a rdf:Property ; rdfs:domain mem:Technology ;
    rdfs:comment "e.g. language, framework, tool, platform" .

# Decision scalars
mem:rationale a rdf:Property ; rdfs:domain mem:Decision .
mem:outcome a rdf:Property ; rdfs:domain mem:Decision .
mem:date a rdf:Property ; rdfs:range xsd:date .

# Pattern scalars
mem:example a rdf:Property ; rdfs:domain mem:Pattern .

# Concept scalars
mem:label a rdf:Property ; rdfs:comment "Display label for concepts." .

# Skill metadata (on the link, not the concept itself)
mem:proficiency a rdf:Property ;
    rdfs:comment "Proficiency level on a skill link (beginner, intermediate, advanced, expert)." .

# Soft delete
mem:invalidated a rdf:Property ; rdfs:range xsd:boolean .
mem:invalidatedAt a rdf:Property ; rdfs:range xsd:dateTime .
mem:invalidationReason a rdf:Property .

# ============================================================
# CROSS-GRAPH RELATIONSHIPS (stored in links graph)
# ============================================================

mem:CrossLink a rdfs:Class ;
    rdfs:label "Cross Link" ;
    rdfs:comment "A relationship between two resource instances, stored separately." .

mem:linkSource a rdf:Property ; rdfs:domain mem:CrossLink ;
    rdfs:comment "Source resource IRI." .
mem:linkTarget a rdf:Property ; rdfs:domain mem:CrossLink ;
    rdfs:comment "Target resource IRI." .
mem:linkRelation a rdf:Property ; rdfs:domain mem:CrossLink ;
    rdfs:comment "Relationship type name." .
mem:linkCreatedAt a rdf:Property ; rdfs:domain mem:CrossLink ; rdfs:range xsd:dateTime .

# Relationship types (used as values of mem:linkRelation)
mem:worksOn a rdf:Property ;
    rdfs:label "works on" ;
    rdfs:comment "Person works on Project." .

mem:employedBy a rdf:Property ;
    rdfs:label "employed by" ;
    rdfs:comment "Person employed by Company." .

mem:owns a rdf:Property ;
    rdfs:label "owns" ;
    rdfs:comment "Company owns Project." .

mem:uses a rdf:Property ;
    rdfs:label "uses" ;
    rdfs:comment "Project uses Technology." .

mem:madeBy a rdf:Property ;
    rdfs:label "made by" ;
    rdfs:comment "Decision made by Person." .

mem:affects a rdf:Property ;
    rdfs:label "affects" ;
    rdfs:comment "Decision affects Project/Task." .

mem:assignedTo a rdf:Property ;
    rdfs:label "assigned to" ;
    rdfs:comment "Task assigned to Person." .

mem:partOf a rdf:Property ;
    rdfs:label "part of" ;
    rdfs:comment "Task part of Project." .

mem:relatesTo a rdf:Property ;
    rdfs:label "relates to" ;
    rdfs:comment "General association between any two resources." .

mem:supersedes a rdf:Property ;
    rdfs:label "supersedes" ;
    rdfs:comment "This resource replaces an earlier one." .

mem:resolves a rdf:Property ;
    rdfs:label "resolves" ;
    rdfs:comment "Decision resolves Task." .

mem:appliesTo a rdf:Property ;
    rdfs:label "applies to" ;
    rdfs:comment "Pattern/Constraint applies to Project." .

mem:hasSkill a rdf:Property ;
    rdfs:label "has skill" ;
    rdfs:comment "Person has Skill concept." .

mem:hasConcept a rdf:Property ;
    rdfs:label "has concept" ;
    rdfs:comment "Resource links to a Concept." .

mem:hasConstraint a rdf:Property ;
    rdfs:label "has constraint" ;
    rdfs:comment "Resource has a Constraint." .

mem:hasPreference a rdf:Property ;
    rdfs:label "has preference" ;
    rdfs:comment "Person has a Preference." .
